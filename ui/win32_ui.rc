
IDI_ICON1 ICON DISCARDABLE "resources/mgrs_icon.ico"

IDR_MENU1 MENU DISCARDABLE
BEGIN
    POPUP "&Help"
    BEGIN
        MENUITEM "&Documentation", IDM_DOCUMENTATION
    END
END

IDD_DIALOG1 DIALOGEX 0, 0, 800, 600
STYLE DS_SETFONT | DS_FIXEDSYS | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX
CAPTION "MGR-S"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "Exit", IDC_EXIT_BUTTON, 700, 570, 80, 20, 0, WS_EX_RIGHT
    CTEXT           "MGR-S", IDC_LOGO_LABEL, 10, 10, 100, 20
    CTEXT           "Version 0.1 ALPHA", IDC_VERSION_LABEL, 120, 10, 100, 20
    CTEXT           "RUNNING", IDC_STATE_LABEL, 650, 10, 100, 20
    CTEXT           "API Version: Unavailable", IDC_API_VERSION_LABEL, 10, 50, 100, 20
    CTEXT           "GPU Count: Unavailable", IDC_GPU_COUNT_LABEL, 10, 70, 100, 20
    CTEXT           "Authority GPU: Unavailable", IDC_AUTHORITY_GPU_LABEL, 10, 90, 100, 20
    EDITTEXT        IDC_LOG_EDIT, 10, 130, 780, 420, ES_MULTILINE | ES_READONLY | WS_VSCROLL
END

STRINGTABLE DISCARDABLE
BEGIN
    IDM_DOCUMENTATION "Documentation"
    IDC_EXIT_BUTTON "Exit"
    IDC_LOGO_LABEL "MGR-S"
    IDC_VERSION_LABEL "Version 0.1 ALPHA"
    IDC_STATE_LABEL "RUNNING"
    IDC_API_VERSION_LABEL "API Version: Unavailable"
    IDC_GPU_COUNT_LABEL "GPU Count: Unavailable"
    IDC_AUTHORITY_GPU_LABEL "Authority GPU: Unavailable"
    IDC_LOG_EDIT "Log output..."
END
